APP_NAME="ArmoryDB - 10RCDG Firearm Tracking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_PH

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ----- Database (MySQL/MariaDB via XAMPP) -----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=armorydb
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=15
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=armorydb_

# ----- Sanctum / SPA -----
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ----- Mail (configure for prod) -----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="armory@10rcdg.mil.ph"
MAIL_FROM_NAME="${APP_NAME}"

# ----- ArmoryDB Specific -----
ARMORY_GPS_INTERVAL_SECONDS=30
ARMORY_GPS_LATENCY_BUDGET_SECONDS=5
ARMORY_GPS_ACCURACY_METERS=10
ARMORY_SESSION_TIMEOUT_MINUTES=15
ARMORY_RATE_LIMIT_PER_SECOND=5
ARMORY_FAILED_LOGIN_THRESHOLD=3
ARMORY_DEFAULT_OVERDUE_HOURS=24

# IoT shared secret used by ESP32 to sign GPS payloads (HMAC-SHA256)
IOT_HMAC_SECRET=

# Google reCAPTCHA v3 (configure for prod)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Google Authenticator (TOTP)
TOTP_ISSUER="ArmoryDB-10RCDG"
TOTP_DIGITS=6
TOTP_PERIOD=30

VITE_APP_NAME="${APP_NAME}"
